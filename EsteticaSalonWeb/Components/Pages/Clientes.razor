@page "/clientes"
@using EsteticaSalonWeb.Models
@using EsteticaSalonWeb.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Gestión de Clientes - Estética</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-primary"><i class="bi bi-people-fill"></i> Control de Clientes</h1>
        <button class="btn btn-success" @onclick="AbrirModalCrear">
            <i class="bi bi-plus-circle-fill"></i> Registrar Nuevo Cliente
        </button>
    </div>

    @if (listaClientes == null)
    {
        <div class="text-center my-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="text-muted mt-2">Cargando base de datos de Azure SQL...</p>
        </div>
    }
    else if (!listaClientes.Any())
    {
        <div class="alert alert-info text-center shadow-sm">
            <i class="bi bi-info-circle-fill fs-3 d-block mb-2"></i>
            No hay clientes registrados en el sistema. ¡Comienza agregando el primero!
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded-3">
            <table class="table table-hover align-middle bg-white m-0">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nombre Completo</th>
                        <th>Teléfono</th>
                        <th>Correo Electrónico</th>
                        <th>Fecha de Registro</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cliente in listaClientes)
                    {
                        <tr>
                            <td class="fw-bold text-secondary">#@cliente.Id</td>
                            <td>@cliente.Nombre</td>
                            <td>@cliente.Telefono</td>
                            <td>@cliente.Email</td>
                            <td>@cliente.FechaRegistro.ToString("dd/MM/yyyy hh:mm tt")</td>
                            <td class="text-center">
                                <button class="btn btn-warning btn-sm me-1" @onclick="() => AbrirModalEditar(cliente)">
                                    <span>Editar</span>
                                </button>
                                <button class="btn btn-danger btn-sm" @onclick="() => EliminarCliente(cliente.Id)">
                                    <span>Eliminar</span>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (mostrarModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title fw-bold">
                        @(clienteFormulario.Id == 0 ? "Registrar Nuevo Cliente" : "Modificar Datos del Cliente")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModal"></button>
                </div>
                
                <EditForm Model="clienteFormulario" OnValidSubmit="GuardarCliente">
                    <DataAnnotationsValidator />
                    
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Nombre Completo</label>
                            <InputText class="form-control" @bind-Value="clienteFormulario.Nombre" placeholder="Ej. Juan Pérez" />
                            <ValidationMessage For="() => clienteFormulario.Nombre" class="text-danger small" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Teléfono</label>
                            <InputText class="form-control" @bind-Value="clienteFormulario.Telefono" placeholder="Ej. 3121234567" />
                            <ValidationMessage For="() => clienteFormulario.Telefono" class="text-danger small" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Correo Electrónico</label>
                            <InputText class="form-control" @bind-Value="clienteFormulario.Email" placeholder="juan@ejemplo.com" />
                            <ValidationMessage For="() => clienteFormulario.Email" class="text-danger small" />
                        </div>
                    </div>
                    
                    <div class="modal-footer bg-light">
                        <button type="button" class="btn btn-secondary" @onclick="CerrarModal">Cancelar</button>
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-cloud-arrow-up-fill"></i> Guardar en Azure
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private List<Cliente>? listaClientes;
    private Cliente clienteFormulario = new();
    private bool mostrarModal = false;

    protected override async Task OnInitializedAsync()
    {
        await CargarClientes();
    }

    private async Task CargarClientes()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        listaClientes = await context.Clientes.OrderByDescending(c => c.Id).ToListAsync();
    }

    private void AbrirModalCrear()
    {
        clienteFormulario = new Cliente(); // Limpiar el formulario
        mostrarModal = true;
    }

    private void AbrirModalEditar(Cliente clienteSeleccionado)
    {
        // Creamos una copia para no alterar la lista principal directamente antes de guardar
        clienteFormulario = new Cliente
        {
            Id = clienteSeleccionado.Id,
            Nombre = clienteSeleccionado.Nombre,
            Telefono = clienteSeleccionado.Telefono,
            Email = clienteSeleccionado.Email,
            FechaRegistro = clienteSeleccionado.FechaRegistro
        };
        mostrarModal = true;
    }

    private void CerrarModal()
    {
        mostrarModal = false;
    }

    private async Task GuardarCliente()
    {
        using var context = await DbFactory.CreateDbContextAsync();

        if (clienteFormulario.Id == 0)
        {
            // Es un cliente nuevo: Insertar (Create)
            context.Clientes.Add(clienteFormulario);
        }
        else
        {
            // Es un cliente existente: Modificar (Update)
            context.Entry(clienteFormulario).State = EntityState.Modified;
        }

        await context.SaveChangesAsync();
        mostrarModal = false;
        await CargarClientes(); // Recargar la tabla con los datos frescos de Azure
    }

    private async Task EliminarCliente(int id)
    {
        using var context = await DbFactory.CreateDbContextAsync();
        var cliente = await context.Clientes.FindAsync(id);
        
        if (cliente != null)
        {
            context.Clientes.Remove(cliente); // Borrar (Delete)
            await context.SaveChangesAsync();
            await CargarClientes(); // Recargar la tabla
        }
    }
}